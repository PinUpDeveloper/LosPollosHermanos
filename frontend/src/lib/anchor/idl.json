  "types": [
    {
      "name": "Campaign",
      "docs": [
        "On-chain state that tracks every campaign through its lifecycle."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "farmer",
            "docs": [
              "The farmer who created the campaign."
            ],
            "type": "pubkey"
          },
          {
            "name": "oracle",
            "docs": [
              "An oracle/authority that can confirm harvests."
            ],
            "type": "pubkey"
          },
          {
            "name": "campaign_id",
            "docs": [
              "Unique numeric id chosen by the farmer."
            ],
            "type": "u64"
          },
          {
            "name": "title",
            "docs": [
              "Human-readable title (≤ TITLE_MAX_LEN bytes)."
            ],
            "type": "string"
          },
          {
            "name": "description",
            "docs": [
              "Human-readable description (≤ DESCRIPTION_MAX_LEN bytes)."
            ],
            "type": "string"
          },
          {
            "name": "total_supply",
            "docs": [
              "Total number of share-tokens available for sale."
            ],
            "type": "u64"
          },
          {
            "name": "tokens_sold",
            "docs": [
              "Number of share-tokens sold so far."
            ],
            "type": "u64"
          },
          {
            "name": "price_per_token",
            "docs": [
              "Price-per-token in USDC lamports (6 decimals)."
            ],
            "type": "u64"
          },
          {
            "name": "vault",
            "docs": [
              "PDA token-account that holds investor USDC."
            ],
            "type": "pubkey"
          },
          {
            "name": "token_mint",
            "docs": [
              "Mint of the share-token (decimals = 0)."
            ],
            "type": "pubkey"
          },
          {
            "name": "status",
            "docs": [
              "Current lifecycle stage."
            ],
            "type": {
              "defined": {
                "name": "CampaignStatus"
              }
            }
          },
          {
            "name": "harvest_total_usdc",
            "docs": [
              "Total harvest revenue in USDC lamports, set by oracle."
            ],
            "type": "u64"
          },
          {
            "name": "proof_hash",
            "docs": [
              "SHA-256 of off-chain proof document."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "created_at",
            "docs": [
              "Unix timestamp of creation."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "CampaignStatus",
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Active"
          },
          {
            "name": "Funded"
          },
          {
            "name": "HarvestSold"
          },
          {
            "name": "Distributed"
          },
          {
            "name": "Completed"
          },
          {
            "name": "Cancelled"
          }
        ]
      }
    },
    {
      "name": "CreateCampaignInput",
      "docs": [
